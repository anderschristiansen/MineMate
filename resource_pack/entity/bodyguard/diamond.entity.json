{
    "format_version": "1.10.0",
    "minecraft:client_entity": {
        "description": {
            "identifier": "minemate:bodyguard_diamond",
            "materials": { "default": "entity_alphatest" },
            "textures": { "default": "textures/entity/diamond" },
            "geometry": { "default": "geometry.humanoid" },
            "animations": {
                "walk": "animation.minemate.companion.walk",
                "look_at_target": "animation.minemate.companion.look",
                "attack": "animation.minemate.companion.attack",
                "controller": "controller.animation.minemate.companion"
            },
            "scripts": {
                "pre_animation": [
                    "variable.tcos0 = math.cos(query.modified_distance_moved * 38.17) * query.modified_move_speed * 57.3;"
                ],
                "animate": [ "controller" ]
            },
            "render_controllers": [ "controller.render.default" ],
            "spawn_egg": { "base_color": "#00BCD4", "overlay_color": "#006978" }
        }
    }
}
