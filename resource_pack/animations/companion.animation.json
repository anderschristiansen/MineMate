{
    "format_version": "1.8.0",
    "animations": {
        "animation.minemate.companion.walk": {
            "loop": true,
            "bones": {
                "rightArm": {
                    "rotation": ["variable.tcos0", 0, 0]
                },
                "leftArm": {
                    "rotation": ["-variable.tcos0", 0, 0]
                },
                "rightLeg": {
                    "rotation": ["-variable.tcos0 * 1.4", 0, 0]
                },
                "leftLeg": {
                    "rotation": ["variable.tcos0 * 1.4", 0, 0]
                }
            }
        },
        "animation.minemate.companion.look": {
            "loop": true,
            "bones": {
                "head": {
                    "rotation": ["query.target_x_rotation", "query.target_y_rotation", 0]
                }
            }
        },
        "animation.minemate.companion.attack": {
            "loop": true,
            "bones": {
                "rightArm": {
                    "rotation": ["math.sin(math.sqrt(variable.attack_time) * 180.0) * -80.0", 0, 0]
                }
            }
        }
    }
}
